# REALMS API (required)
REALMS_API_KEY=your-key-here
REALMS_BASE_URL=https://reallms.rescloud.iu.edu/direct/v1

# Ollama (local router — defaults shown, change if you moved Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ROUTER_MODEL=qwen2.5:1.5b
OLLAMA_CODING_MODEL=qwen2.5-coder:7b

# RAG index directory (path to repos you want indexed)
RAG_INDEX_PATH=~/.orchestrator/chroma
RAG_SOURCE_DIRS=/Users/jelambeadmin/Documents/access-sysops

# Orchestration behaviour
JUDGE_ENABLED=true          # set to false to skip critique pass
JUDGE_MODEL=gpt-oss-120b
PLAN_FIRST=false            # set to true to always show plan + require approval before executing
OFFLINE_MODE=false          # set to true to force local-only (no REALMS calls)
